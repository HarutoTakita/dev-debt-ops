# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/app

# Auth
SECRET_KEY=change-me-in-production-min-32-bytes
COOKIE_SECURE=false
JWT_LIFETIME_SECONDS=300
REFRESH_TOKEN_LIFETIME_SECONDS=604800

# AI (Google Gemini via Vertex AI)
# 1. Service account JSON を ./secrets/gsa.json に配置する
# 2. 下記をコンテナ内パスに設定する（ホストパスではない）
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gsa.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# GitHub App（リポジトリアクセス用）
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=

# GitHub OAuth（ユーザー認証用）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# pgAdmin (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# App
ENVIRONMENT=dev

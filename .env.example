# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/app

# Auth
SECRET_KEY=change-me-in-production-min-32-bytes
COOKIE_SECURE=false
JWT_LIFETIME_SECONDS=300
REFRESH_TOKEN_LIFETIME_SECONDS=604800

# AI (Google Gemini via Vertex AI)
# 1. Service account JSON を ./secrets/gsa.json に配置する
# 2. 下記をコンテナ内パスに設定する（ホストパスではない）
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gsa.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Vertex AI / Cloud Tasks / GCS で共用するリージョン（issue 016/017 で統一）
GOOGLE_CLOUD_LOCATION=asia-northeast1

# 非同期タスクキュー（issue 016）。既定はすべて mock で GCP 不要のままローカル動作する
# （ただし mock-worker は echo/ping のみ実行可。service 専用の stack_analysis は実行できない）。
USE_MOCK_QUEUE=true
USE_MOCK_WORKER=true
USE_MOCK_BLOB=true
# ローカルで service コンテナへ HTTP 直送し stack_analysis を実機実行したい場合は true にする（issue 018）。
# true のとき in-process mock-worker は無効化され、SERVICE_TASKS_URL 宛に dispatch する（compose では http://service:8000）。
USE_LOCAL_SERVICE=false
# 本番（Cloud Tasks）/ ローカル（USE_LOCAL_SERVICE=true）での service の宛先 URL。
SERVICE_TASKS_URL=http://localhost:8001
TASKS_INVOKER_SA=
TASKS_QUEUE=job-requests
JOB_PAYLOAD_BUCKET=

# GitHub App（リポジトリアクセス用）
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=

# GitHub OAuth（ユーザー認証用）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# pgAdmin (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# App
ENVIRONMENT=dev

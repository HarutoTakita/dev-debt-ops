# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/app

# Auth
SECRET_KEY=change-me-in-production-min-32-bytes
COOKIE_SECURE=false
JWT_LIFETIME_SECONDS=28800
REFRESH_TOKEN_LIFETIME_SECONDS=2592000

# AI (Google Gemini via Vertex AI)
# 1. Service account JSON を ./secrets/gsa.json に配置する
# 2. 下記をコンテナ内パスに設定する（ホストパスではない）
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gsa.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Vertex AI / Cloud Tasks / GCS で共用するリージョン（issue 016/017 で統一）
GOOGLE_CLOUD_LOCATION=asia-northeast1

# 非同期タスクキュー（issue 016）。既定はすべて mock で GCP 不要のままローカル動作する
# （ただし mock-worker は echo/ping のみ実行可。service 専用の stack_analysis は実行できない）。
# 注意: USE_MOCK_QUEUE=true は service の `/tasks/{pipeline}` の OIDC 検証を無効化する dev 専用設定。
# 非 dev（stg/prod）では false 必須（true だと service 起動が失敗する＝fail-closed、issue 038）。
USE_MOCK_QUEUE=true
USE_MOCK_WORKER=true
USE_MOCK_BLOB=true
# ローカルで service コンテナへ HTTP 直送し stack_analysis を実機実行したい場合は true にする（issue 018）。
# true のとき in-process mock-worker は無効化され、SERVICE_TASKS_URL 宛に dispatch する（compose では http://service:8000）。
USE_LOCAL_SERVICE=false
# 本番（Cloud Tasks）/ ローカル（USE_LOCAL_SERVICE=true）での service の宛先 URL。
SERVICE_TASKS_URL=http://localhost:8001
TASKS_INVOKER_SA=
TASKS_QUEUE=job-requests
JOB_PAYLOAD_BUCKET=

# GitHub App（リポジトリアクセス用）
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=

# GitHub OAuth（ユーザー認証用）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# pgAdmin (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# App
ENVIRONMENT=dev

# フィーチャーフラグ
# ゲストデモ（GitHub 不要の「お試しはこちら」＋サンプルデータ）を有効化する（issue 069）。本番では false 推奨。
DEMO_MODE_ENABLED=false
# ユーザー単位の解析クレジットを有効化する（issue 298）。true のとき「リポジトリ解析」1 回でクレジットを 1 消費し、
# 修正 PR 作成は残高がないと実行不可（Gemini コストの上限化）。クレジット初期値は 0 で、管理者(superuser)が付与する。
# false（既定）ではゲートを完全にバイパス（無制限）。superuser・ゲストデモは常に対象外。
ANALYSIS_CREDITS_ENABLED=false

# 管理者（superuser）アカウント（issue 300）。カンマ区切りのメールアドレスを列挙する。ここに載っているアカウント
# *だけ* が管理画面（/admin・クレジット付与等）にアクセスできる。ログインのたびに is_superuser がこの値と整合され、
# GitHub SSO ユーザーは既定で一般ユーザーになる（大文字小文字は無視）。空（既定）＝管理者なし。
ADMIN_EMAILS=

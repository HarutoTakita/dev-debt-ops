<mxfile host="app.diagrams.net" agent="rosetta-docs" version="24.0.0">
  <diagram id="rosetta-gcp-arch" name="GCP Architecture">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Rosetta — GCP インフラ構成 (infra/gcp ・ Cloud Run + Cloud SQL)" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- ===== External actors ===== -->
        <mxCell id="g_ext" value="外部 / クライアント" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;verticalAlign=top;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="180" height="560" as="geometry" />
        </mxCell>
        <mxCell id="dev" value="🧑‍💻 開発者 / チーム&#10;(ブラウザ SPA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cicd" value="⚙️ GitHub Actions&#10;(CI/CD ・ issue-025)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#5e35b1;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="github" value="🐙 GitHub&#10;OAuth / App / REST API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#455a64;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- ===== GCP project boundary ===== -->
        <mxCell id="gcp" value="☁️ Google Cloud Project  (region: asia-northeast1 / name_prefix: fullstack-app-an1-{stg|prod})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;verticalAlign=top;fontStyle=1;fontSize=13;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="260" y="70" width="1200" height="940" as="geometry" />
        </mxCell>

        <!-- Edge layer -->
        <mxCell id="armor" value="🛡️ Cloud Armor&#10;security policy&#10;(login 5/min,10/h ; refresh 30/min)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce8e6;strokeColor=#c5221f;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lb" value="🌐 External HTTPS LB&#10;+ Serverless NEG&#10;(managed cert ・ var.domain)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#137333;" vertex="1" parent="1">
          <mxGeometry x="520" y="150" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Cloud Run api -->
        <mxCell id="api" value="🟦 Cloud Run: api&#10;ingress = INTERNAL_LOAD_BALANCER&#10;SPA 配信 + /api/v1/*&#10;USE_MOCK_* = false" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d2e3fc;strokeColor=#1967d2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="140" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Cloud Tasks -->
        <mxCell id="tasks" value="📨 Cloud Tasks&#10;queue: job-requests&#10;(rate/retry, dedup_key=job.id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#ea8600;" vertex="1" parent="1">
          <mxGeometry x="760" y="300" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Cloud Run service -->
        <mxCell id="svc" value="🟪 Cloud Run: service&#10;ingress = INTERNAL_ONLY&#10;POST /tasks/{pipeline} (OIDC 検証)&#10;run_task → Job を Cloud SQL に直書き" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e9d2fc;strokeColor=#8430ce;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="440" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="pipes" value="pipelines: stack_analysis ・ code_debt_detection ・ kc_analysis ・ knowledge_debt_detection ・ repayment_pr_generation ・ quiz_generation/grading ・ learning_plan_generation ・ agent_loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8fd;strokeColor=#8430ce;dashed=1;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="760" y="560" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- VPC connector + Cloud SQL -->
        <mxCell id="vpc" value="🔌 Serverless VPC Access connector&#10;(custom VPC ・ private service access)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#137333;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="700" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sql" value="🐘 Cloud SQL — PostgreSQL 17 (pgvector)&#10;prod=private IP/REGIONAL ・ stg=public/ZONAL&#10;Job / TechStack / analysis_run / code_debt / file_kc / …" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d2e3fc;strokeColor=#1967d2;" vertex="1" parent="1">
          <mxGeometry x="500" y="820" width="280" height="100" as="geometry" />
        </mxCell>

        <!-- Right column managed services -->
        <mxCell id="sm" value="🔐 Secret Manager&#10;secret-key / github-app-private-key /&#10;github-client-secret / github-webhook-secret /&#10;database-url  (google-api-key 無し)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce8e6;strokeColor=#c5221f;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1040" y="140" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="gcs" value="🪣 GCS: *-job-payloads&#10;request spill ($requestRef)&#10;UBLA ・ 7日で削除" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#137333;" vertex="1" parent="1">
          <mxGeometry x="1040" y="300" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="vertex" value="✨ Vertex AI (Gemini)&#10;ADC 認証 ・ API キー不使用&#10;roles/aiplatform.user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#ea8600;" vertex="1" parent="1">
          <mxGeometry x="1040" y="440" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ar" value="📦 Artifact Registry (DOCKER)&#10;api / service イメージ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaed;strokeColor=#5f6368;" vertex="1" parent="1">
          <mxGeometry x="1040" y="580" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="obs" value="📈 Cloud Logging / Monitoring / Trace&#10;log-based 5xx metric + alert + uptime check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaed;strokeColor=#5f6368;" vertex="1" parent="1">
          <mxGeometry x="1040" y="820" width="240" height="100" as="geometry" />
        </mxCell>

        <!-- Bootstrap / WIF -->
        <mxCell id="wif" value="🔑 bootstrap: Workload Identity Federation&#10;pool/provider (repo + environment ピン留め)&#10;→ deploy SA (gh-deploy) ・ tfstate bucket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#5e35b1;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="380" width="300" height="90" as="geometry" />
        </mxCell>

        <!-- ===== Edges ===== -->
        <!-- user/browser path -->
        <mxCell id="e_user_armor" value="HTTPS" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="dev" target="armor"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_armor_lb" style="endArrow=block;html=1;" edge="1" parent="1" source="armor" target="lb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_lb_api" style="endArrow=block;html=1;" edge="1" parent="1" source="lb" target="api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_user_gh" value="OAuth ログイン" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="dev" target="github"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- api → tasks → service -->
        <mxCell id="e_api_tasks" value="enqueue (cloudtasks.enqueuer)" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="api" target="tasks"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_tasks_svc" value="OIDC HTTP /tasks/{pipeline}" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="tasks" target="svc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_svc_pipes" style="endArrow=none;html=1;dashed=1;" edge="1" parent="1" source="svc" target="pipes"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- DB access via VPC connector -->
        <mxCell id="e_api_vpc" value="read/write" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="api" target="vpc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_svc_vpc" value="Job 結果を直書き" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="pipes" target="vpc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_vpc_sql" style="endArrow=block;html=1;" edge="1" parent="1" source="vpc" target="sql"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- secrets / gcs -->
        <mxCell id="e_api_sm" value="secret 参照" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="api" target="sm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_svc_sm" value="GitHub App 秘密鍵 (方式B)" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="svc" target="sm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_api_gcs" value="spill" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="api" target="gcs"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_svc_gcs" value="read spill" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="svc" target="gcs"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- service externals -->
        <mxCell id="e_svc_vertex" value="分類/生成" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="svc" target="vertex"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_svc_gh" value="履歴/ファイル/PR" style="endArrow=block;html=1;dashed=1;fontSize=10;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="svc" target="github"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_api_gh" value="installation token" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="api" target="github"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- registry → run -->
        <mxCell id="e_ar_api" value="image" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="ar" target="api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ar_svc" value="image" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="ar" target="svc"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- observability -->
        <mxCell id="e_api_obs" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="api" target="obs"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_svc_obs" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="svc" target="obs"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- CI/CD -->
        <mxCell id="e_cicd_wif" value="OIDC (repo+env)" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="cicd" target="wif"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_wif_ar" value="push image" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="wif" target="ar"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_wif_api" value="terraform apply" style="endArrow=block;html=1;dashed=1;fontSize=10;" edge="1" parent="1" source="wif" target="api"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- legend -->
        <mxCell id="legend" value="凡例:  実線 = 同期/主経路   破線 = 補助(秘密参照・spill・ログ・image・外部API)&#10;結果は service が Cloud SQL の Job 行を直接更新 (Pub/Sub・コールバック無し)。フロントは GET /api/v1/jobs/{id} をポーリング。" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#ffffff;strokeColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="300" y="490" width="430" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
